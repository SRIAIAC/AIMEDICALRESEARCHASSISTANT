ENVIRONMENT=development

# LLM: "ollama" runs fully locally with no API key (needs `ollama serve` +
# a pulled model); switch to "anthropic" and set ANTHROPIC_API_KEY for the
# hosted Claude API instead.
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
OPENAI_API_KEY=

# Embeddings: "ollama" uses a local Ollama embedding model (real semantic
# search, no extra install — just `ollama pull nomic-embed-text`); "hash"
# is a dependency-free bag-of-words fallback with much weaker retrieval
# quality; "sentence_transformers" needs the optional dependency installed
# (see requirements.txt).
EMBEDDING_PROVIDER=ollama
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Vector store
VECTOR_STORE_PROVIDER=chroma
CHROMA_PERSIST_DIR=./data/chroma
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/medresearch

# External data sources
PUBMED_API_KEY=
NCBI_EMAIL=
DRUGBANK_API_KEY=

# Auth
JWT_SECRET_KEY=change-me
