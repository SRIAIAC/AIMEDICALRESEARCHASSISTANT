# Copy to backend/.env.prod and fill in before deploying with
# docker-compose.prod.yml. OLLAMA_BASE_URL is set by docker-compose itself
# (points at the `ollama` service) — no need to set it here.

ENVIRONMENT=production

LLM_PROVIDER=ollama
OLLAMA_MODEL=llama3.2
EMBEDDING_PROVIDER=ollama
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

VECTOR_STORE_PROVIDER=chroma
CHROMA_PERSIST_DIR=/app/data/chroma

# Optional — higher PubMed rate limits if set
PUBMED_API_KEY=
NCBI_EMAIL=

# Generate a real secret before deploying, e.g.: openssl rand -hex 32
JWT_SECRET_KEY=change-me

# Comma-separated. Caddy puts frontend+backend on the same origin, so this
# is a fallback rather than something the browser actually relies on — set
# it to your real domain/IP anyway in case anything calls the API directly.
CORS_ORIGINS=http://localhost:3000
